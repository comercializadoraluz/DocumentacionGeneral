        <mxCell id="KmjViTt1OgNbIoApywmM-6" value="Cambios de la tabla peaje, carga segmento tarifario. &lt;br&gt;Si se cambia el nombre (que en realidad es borrar y meter uno nuevo):&lt;br&gt;En el csv&amp;nbsp; &amp;nbsp;&amp;nbsp;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=60;" vertex="1" parent="GQnUoAlBmg71Q_VHU6vH-1">
