        <mxCell id="tNK4t-sKAai_ePAIEb7G-4" parent="1" style="text;whiteSpace=wrap;" value="CREACION DE VISTA DE VISTA_HORA_ANUAL&#xa;&#xa;POSTGRESQL&#xa;CREATE TABLE resolucion (&#xa;    id_resolucion SERIAL PRIMARY KEY,&#xa;    nombre VARCHAR(10) UNIQUE NOT NULL&#xa;);&#xa;&#xa;INSERT INTO resolucion (nombre) VALUES&#xa;(&#39;PT15M&#39;),&#xa;(&#39;PT30M&#39;),&#xa;(&#39;PT60M&#39;),&#xa;(&#39;P1D&#39;);&#xa;&#xa;&#xa;CREATE TABLE horarios (&#xa;    id_horarios serial PRIMARY KEY,&#xa;    fechahora TIMESTAMP WITH TIME ZONE not null,&#xa;    id_resolucion int not null references resolucion(id_resolucion)&#xa;);&#xa;&#xa;&#xa;INSERT INTO horarios (fechahora, id_resolucion) VALUES&#xa;-- PT60M (originales)&#xa;(&#39;2023-10-28 22:00:00+00&#39;, 3),&#xa;(&#39;2023-10-28 23:00:00+00&#39;, 3),&#xa;(&#39;2023-10-29 00:00:00+00&#39;, 3),&#xa;(&#39;2023-10-29 01:00:00+00&#39;, 3),&#xa;(&#39;2023-10-29 02:00:00+00&#39;, 3),&#xa;(&#39;2023-10-29 03:00:00+00&#39;, 3),&#xa;-- PT15M (divididos en intervalos de 15 minutos)&#xa;(&#39;2023-10-28 22:00:00+00&#39;, 1),&#xa;(&#39;2023-10-28 22:15:00+00&#39;, 1),&#xa;(&#39;2023-10-28 22:30:00+00&#39;, 1),&#xa;(&#39;2023-10-28 22:45:00+00&#39;, 1),&#xa;(&#39;2023-10-28 23:00:00+00&#39;, 1),&#xa;(&#39;2023-10-28 23:15:00+00&#39;, 1),&#xa;(&#39;2023-10-28 23:30:00+00&#39;, 1),&#xa;(&#39;2023-10-28 23:45:00+00&#39;, 1),&#xa;(&#39;2023-10-29 00:00:00+00&#39;, 1),&#xa;(&#39;2023-10-29 00:15:00+00&#39;, 1),&#xa;(&#39;2023-10-29 00:30:00+00&#39;, 1),&#xa;(&#39;2023-10-29 00:45:00+00&#39;, 1),&#xa;(&#39;2023-10-29 01:00:00+00&#39;, 1),&#xa;(&#39;2023-10-29 01:15:00+00&#39;, 1),&#xa;(&#39;2023-10-29 01:30:00+00&#39;, 1),&#xa;(&#39;2023-10-29 01:45:00+00&#39;, 1),&#xa;(&#39;2023-10-29 02:00:00+00&#39;, 1),&#xa;(&#39;2023-10-29 02:15:00+00&#39;, 1),&#xa;(&#39;2023-10-29 02:30:00+00&#39;, 1),&#xa;(&#39;2023-10-29 02:45:00+00&#39;, 1),&#xa;(&#39;2023-10-29 03:00:00+00&#39;, 1),&#xa;(&#39;2023-10-29 03:15:00+00&#39;, 1),&#xa;(&#39;2023-10-29 03:30:00+00&#39;, 1),&#xa;(&#39;2023-10-29 03:45:00+00&#39;, 1);&#xa;&#xa;CREATE TABLE zona_horaria (&#xa;    id_zona_horaria SERIAL PRIMARY KEY,&#xa;    zona VARCHAR(50) unique not null,&#xa;    nombre_zona VARCHAR(50) UNIQUE NOT NULL&#xa;);&#xa;&#xa;INSERT INTO zona_horaria (zona, nombre_zona) VALUES&#xa;(&#39;Europe/Madrid&#39;, &#39;Península&#39;),&#xa;(&#39;Atlantic/Canary&#39;, &#39;Canarias&#39;);&#xa;&#xa;With horarios_fechahora_local AS (&#xa;  SELECT &#xa;    *,&#xa;    fechahora at time zone zona as fechahora_local&#xa;  FROM horarios&#xa;  natural join resolucion&#xa;  cross join zona_horaria&#xa;  where id_resolucion in (1, 3)&#xa;),&#xa;horarios_todos_los_datos as (&#xa;  select&#xa;    fechahora,&#xa;    fechahora_local,&#xa;    fechahora_local::date AS fecha_local,&#xa;    EXTRACT(HOUR FROM fechahora_local) + 1 AS periodo,&#xa;    to_char(fechahora_local, &#39;HH24:MI&#39;) AS hora_inicio_local,&#xa;    case&#xa;      when id_resolucion = 3 then to_char(fechahora_local + interval &#39;1 hour&#39;, &#39;HH24:MI&#39;)&#xa;      else to_char(fechahora_local + interval &#39;15 minutes&#39;, &#39;HH24:MI&#39;)&#xa;    end as hora_fin_local,&#xa;    ROW_NUMBER() OVER (&#xa;      PARTITION BY fechahora_local::date, fechahora_local::time, id_zona_horaria, id_resolucion&#xa;      ORDER BY fechahora&#xa;    ) AS hora_row,&#xa;    nombre as resolucion,&#xa;    id_resolucion,&#xa;    nombre_zona,&#xa;    id_zona_horaria&#xa;  from horarios_fechahora_local&#xa;)&#xa;SELECT&#xa;  fechahora,&#xa;  fechahora_local,&#xa;  fecha_local,&#xa;  case&#xa;    when id_resolucion = 3 then periodo&#xa;    else ((periodo - 1) * 4 + 1) + floor(extract(minute from fechahora_local) / 15)&#xa;  end as periodo,&#xa;  hora_inicio_local,&#xa;  hora_fin_local,&#xa;  resolucion,&#xa;  nombre_zona,&#xa;  CASE&#xa;    WHEN hora_row = 2 THEN TRUE&#xa;    ELSE null&#xa;  END AS hora_25&#xa;FROM horarios_todos_los_datos&#xa;ORDER BY id_zona_horaria, id_resolucion desc, fechahora;" vertex="1">
          <mxGeometry height="1680" width="560" x="-10520" y="2350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
